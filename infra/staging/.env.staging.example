# =============================================================================
# Staging .env template. Real values land in /opt/crm-app/docker/.env.staging
# on the staging box (chmod 600, root-owned, NEVER committed).
#
# Required for boot; the api/worker container fail-fast on missing values
# (config/index.ts requireEnv).
#
# Generate the random secrets with:
#   openssl rand -hex 32             # for HMAC-style
#   openssl rand -base64 32          # for symmetric encryption keys
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =============================================================================

# ---- Database -------------------------------------------------------------
POSTGRES_USER=acs_user
POSTGRES_PASSWORD=<strong-random-32+chars>
POSTGRES_DB=acs_db

# ---- Redis ----------------------------------------------------------------
REDIS_PASSWORD=<strong-random-32+chars>

# ---- Server ---------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ---- JWT (memory rule: rotation slots OLD_* present for zero-downtime) ----
JWT_SECRET=<openssl rand -hex 32>
JWT_REFRESH_SECRET=<openssl rand -hex 32>
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d
# OLD_JWT_SECRET=<populate during rotation only>
# OLD_JWT_REFRESH_SECRET=<populate during rotation only>

# ---- Session --------------------------------------------------------------
SESSION_SECRET=<openssl rand -hex 32>
BCRYPT_ROUNDS=12

# ---- Audit log HMAC chain (T1-1, required in prod) ------------------------
AUDIT_LOG_HMAC_SECRET=<openssl rand -hex 32>

# ---- MFA TOTP encryption (T1-2, required in prod) -------------------------
MFA_ENCRYPTION_KEY=<32-byte base64 — node -e "console.log(require('crypto').randomBytes(32).toString('base64'))">

# ---- Google Maps (server-side reverse geocode) ----------------------------
GOOGLE_MAPS_API_KEY=<from Google Cloud Console — IP-restricted to box public IP>

# ---- Firebase Admin SDK (FCM push) ----------------------------------------
# File-based: drop service-account JSON at
#   /opt/crm-app/docker/secrets/firebase-service-account.json
# Compose mounts it into the worker container at /run/secrets/firebase-service-account.
# No FIREBASE_SERVICE_ACCOUNT_PATH var needed here — Compose injects it.
FIREBASE_PROJECT_ID=caseflow-mobile

# ---- APNS (iOS push — only set when iOS distribution is provisioned) ------
# When you provision the Apple Developer account ($99/yr) and generate the
# APNs auth key (.p8), enable APNS push:
#   1. Drop the .p8 file at /opt/crm-app/docker/secrets/apns.p8 (root:600)
#   2. Uncomment the apns secret stanza in infra/staging/docker-compose.yml
#      AND add `- apns` to the worker service's `secrets:` list
#   3. Uncomment + populate the 4 vars below
#      (or via: scripts/staging-env-set.sh set APNS_KEY_ID <value> etc.)
# APNS_KEY_PATH=/run/secrets/apns
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.crmmobilenative

# ---- Email (SMTP) ---------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ---- CORS -----------------------------------------------------------------
CORS_ORIGIN=https://crm.allcheckservices.com

# ---- Logging --------------------------------------------------------------
LOG_LEVEL=info

# ---- Storage (S3 deferred to AWS branch; staging = local volume) ----------
STORAGE_BACKEND=local
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=52428800

# ---- GST (Indian tax; invoice numbering depends on this) ------------------
SUPPLIER_GST_STATE_CODE=27
GST_RATE_DEFAULT=18

# ---- Rate limiting --------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5000

# ---- Observability (OTel — off on staging; flip via env when needed) ------
OTEL_ENABLED=false
# OTEL_SERVICE_NAME=crm-backend-staging
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_TRACE_SAMPLING_RATIO=0.1
