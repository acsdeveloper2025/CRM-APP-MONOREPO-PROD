{
  "name": "crm-backend",
  "version": "1.0.0",
  "description": "A backend service for the CRM (Customer Relationship Management) application.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node -r module-alias/register dist/index.js",
    "start:prod": "npm run build && npm start",
    "db:backup": "ts-node scripts/db-backup.ts",
    "db:sync-admin": "ts-node scripts/db-sync-admin.ts",
    "db:reset-local": "ts-node scripts/db-reset-local.ts",
    "db:validate": "ts-node scripts/db-validate.ts",
    "db:export-snapshot": "ts-node scripts/db-export-snapshot.ts",
    "db:prepare-local-main": "npm run db:backup && npm run db:sync-admin && npm run db:validate && npm run db:export-snapshot",
    "clean-and-seed": "node scripts/clean-and-seed-cases.js",
    "verify-cleanup": "ts-node scripts/db-validate.ts",
    "migrate": "ts-node scripts/run-migrations.ts run",
    "migrate:data": "ts-node scripts/run-migrations.ts data",
    "migrate:status": "ts-node scripts/run-migrations.ts status",
    "migrate:rollback": "ts-node scripts/run-migrations.ts rollback",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acsdeveloper2025/CRM-APP-MONOREPO.git"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "express",
    "prisma",
    "mysql",
    "redis",
    "bullmq",
    "acs",
    "backend"
  ],
  "author": "ACS Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/acsdeveloper2025/CRM-APP-MONOREPO/issues"
  },
  "homepage": "https://github.com/acsdeveloper2025/CRM-APP-MONOREPO#readme",
  "_moduleAliases": {
    "@": "dist"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bull": "^3.15.9",
    "@types/sharp": "^0.31.1",
    "@types/socket.io": "^3.0.1",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "bullmq": "^5.56.9",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.0.0",
    "form-data": "^4.0.4",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-apn": "^3.0.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.6",
    "pg": "^8.16.3",
    "pg-format": "^1.0.4",
    "puppeteer": "^24.17.1",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.17.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@express-rate-limit/tsconfig": "^1.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.2.1",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
