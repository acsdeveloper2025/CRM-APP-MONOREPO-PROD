{
  "name": "caseflow-mobile",
  "private": true,
  "version": "4.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5180",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:mobile": "IS_MOBILE_APP=true vite build --mode production",
    "preview": "vite preview",
    "preview:network": "vite preview --host 0.0.0.0",
    "setup-firebase": "./scripts/setup-firebase.sh",
    "android": "npx cap run android",
    "android:build": "npm run build:mobile && npx cap sync android && npx cap run android",
    "ios": "npx cap run ios",
    "ios:build": "npm run build:mobile && npx cap sync ios && npx cap run ios",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "cap:sync": "npx cap sync",
    "cap:sync:ios": "npx cap sync ios && npx cap open ios"
  },
