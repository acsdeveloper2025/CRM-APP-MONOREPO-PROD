# CaseFlow Mobile Environment Configuration

# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the following APIs:
# - Maps JavaScript API
# - Geocoding API
# - Places API (optional)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# App Configuration
VITE_APP_NAME=CaseFlow Mobile
VITE_APP_VERSION=4.0.0
VITE_APP_ENVIRONMENT=development

# API Configuration
# For localhost development (used by default)
VITE_API_BASE_URL=http://localhost:3000/api

# For network access (replace with your device IP)
VITE_API_BASE_URL_DEVICE=http://192.168.1.36:3000/api

# For production deployment
VITE_API_BASE_URL_PRODUCTION=https://your-app-name.onrender.com/api

# Nominatim Configuration
VITE_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
VITE_NOMINATIM_USER_AGENT=CaseFlow-Mobile/4.0.0

# Feature Flags
VITE_ENABLE_GOOGLE_MAPS=true
VITE_ENABLE_LOCATION_VALIDATION=true
VITE_ENABLE_ENHANCED_GEOCODING=true
