# Application Configuration
VITE_APP_NAME=CRM Admin Dashboard
VITE_APP_VERSION=1.0.0

# API Configuration for Internet Access
# Update these URLs with your actual tunnel URLs
VITE_API_BASE_URL=https://your-crm-api.ngrok.io/api
VITE_API_TIMEOUT=10000

# WebSocket Configuration for Internet Access
VITE_WS_URL=wss://your-crm-ws.ngrok.io

# Authentication
VITE_AUTH_PROVIDER=jwt

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MAINTENANCE_MODE=false

# UI Configuration
VITE_THEME=light
VITE_DEFAULT_LOCALE=en

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Production Environment
NODE_ENV=production
PORT=5173
