{
  "name": "crm-app",
  "version": "1.0.0",
  "description": "CRM Application",
  "scripts": {
    "postinstall": "npm --prefix CRM-BACKEND install && npm --prefix CRM-FRONTEND install",
    "setup": "node scripts/setup-local.mjs",
    "dev": "concurrently -n be,fe -c blue,green --kill-others-on-fail \"npm --prefix CRM-BACKEND run dev\" \"npm --prefix CRM-FRONTEND run dev\"",
    "dev:be": "npm --prefix CRM-BACKEND run dev",
    "dev:fe": "npm --prefix CRM-FRONTEND run dev",
    "db:reset": "npm --prefix CRM-BACKEND run db:reset-local",
    "db:migrate": "npm --prefix CRM-BACKEND run migrate",
    "lint": "npm --prefix CRM-BACKEND run lint && npm --prefix CRM-FRONTEND run lint",
    "typecheck": "npm --prefix CRM-BACKEND run typecheck && npm --prefix CRM-FRONTEND run type-check",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "node-fetch": "^3.3.2",
    "playwright": "^1.55.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6"
  },
  "lint-staged": {
    "CRM-FRONTEND/src/**/*.{ts,tsx}": [
      "cd CRM-FRONTEND && npm run lint:fix",
      "cd CRM-FRONTEND && npx prettier --write"
    ],
    "CRM-BACKEND/src/**/*.ts": [
      "cd CRM-BACKEND && npm run lint:fix",
      "cd CRM-BACKEND && npx prettier --write"
    ],
    "crm-mobile-native/src/**/*.{ts,tsx}": [
      "cd crm-mobile-native && npm run lint:fix",
      "cd crm-mobile-native && npx prettier --write"
    ]
  }
}
